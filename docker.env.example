# Copy to "docker.env" in this folder and use: docker compose --env-file docker.env up -d --build
# Or set these in your shell before `docker compose up`.

# --- API URL baked into the frontend (must be reachable from the *browser*). ---
# Local compose with published ports 3000/8080:
VITE_API_BASE_URL=http://localhost:3000

# --- Host ports (optional) ---
# BACKEND_HOST_PORT=3000
# FRONTEND_HOST_PORT=8080
# PORT=3000

# --- PostgreSQL (service `db`) ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=kaizen

# URL used by the backend container (use service name `db`, not localhost)
DATABASE_URL=postgresql://postgres:postgres@db:5432/kaizen?schema=public

# --- App secrets ---
JWT_SECRET=replace-with-a-long-random-string

# --- Optional: Google AI (backend) ---
# GEMINI_API_KEY=

# --- Optional: HRMS source DB (leave empty if not used) ---
# HRMS_DATABASE_URL=postgresql://user:pass@host:5432/hrms?schema=public

# --- Optional: bootstrap a SUPER_ADMIN on first backend start ---
# SUPER_ADMIN_BOOTSTRAP_ENABLED=true
# SUPER_ADMIN_EMPLOYEE_CODE=SUPERADMIN
# SUPER_ADMIN_PASSWORD=ChangeMe@123
# SUPER_ADMIN_EMAIL=admin@local
# SUPER_ADMIN_NAME=Super Admin
