# Copy to .env and adjust for your machine.
# Prisma reads this via prisma.config.ts (CLI) and Nest ConfigModule (runtime).

DATABASE_URL="postgresql://postgres:root@localhost:5432/kaizen_kh?schema=public"
JWT_SECRET="replace-with-strong-secret"
# Backend listen port (default 3000)
PORT="3001"
# Admin / SUPER_ADMIN users: create in DB (users + user_role_mapping). Login uses users table only.

# Optional: auto-create a default SUPER_ADMIN at startup (recommended for dev)
SUPER_ADMIN_BOOTSTRAP_ENABLED="true"
SUPER_ADMIN_EMPLOYEE_CODE="SUPERADMIN"
SUPER_ADMIN_PASSWORD="SuperAdmin@123"
SUPER_ADMIN_EMAIL="superadmin@local"
SUPER_ADMIN_NAME="Super Admin"

# Source DB for HRMS sync (hrms_employees). Sync mirrors into kaizen_kh: hrms_employees, staging, users.
HRMS_DATABASE_URL="postgresql://postgres:root@localhost:5432/kaizen_HRMS?schema=public"
HRMS_SYNC_CRON="*/30 * * * * *"

# Local file storage for Kaizen uploads (idea + template). Served at /kaizen-files/
KAIZEN_UPLOAD_ROOT="C:/data/kaizen_storage"
